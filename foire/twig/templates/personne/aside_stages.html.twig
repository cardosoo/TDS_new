<link rel="stylesheet" href="/{{App.appName}}/assets/knockout/knockout-file-bindings.css">
<script src="/{{App.appName}}/assets/knockout/knockout-file-bindings.js"></script>


<script> 
    univList = [
    "Paris Cité",
    "Panthéon Sorbonne - Paris 1",
    "Panthéon Assas - Paris 2",
    "Sorbonne Nouvelle - Paris 3",
    "Sorbonne Université",
    "PSL (Paris Sciences & Lettres)",
    "Paris 8",
    "Paris Dauphine",
    "Paris Nanterre",
    "Paris-Saclay",
    "Paris-Est Créteil Val de Marne",
    "Gustave Eiffel",
    "UVSQ (Versailles Saint-Quentin-en-Yvelines)",
    "Evry Val d'essonne",
    "Cergy Paris University",
    "Autres...",
    ];

    levelList = [
        'Niveau',
        'L3',
        'M1'
    ];

    tauxList = [
        '1',
        '1/2',
        '1/3',
        '2/3',
        '1/6',
        '5/6'
    ];

</script>


<style>
    p {
        margin: 0px;
    }

    tr.stage {
        background-color: #FADADD;
        border-collapse: collapse;
    }

    tr.valid {
        background-color: #00FF00;
    }

    table.stage {
        border-collapse: collapse;
    }

</style>

<div style='all: revert;'>
    <div class='w3-container w3-card'>
    {% block stage_info %}
        <br>
        <div class="w3-card-4 w3-white ">
            <header class="w3-container w3-light-grey">
                <p>Information stages</p>
            </header>
            <div class='w3-small w3-padding'>
                <p>Il est possible de prendre en compte, dans le service
                des enseignants-chercheurs, l'encadrement des étudiants
                en stage, en <b>L3</b> et en <b>M1</b>
                à raison de 6 heures par étudiant encadré, avec un maximum 
                de <b>12hETD</b> par enseignant par année universitaire.</p>
                <p>Le volant d'heures correspondant apparaît dans la foire sous
                forme d'une fonction du référentiel et est 
                déduit de votre charge d'enseignement. 
                Le <b>décompte n'est pris en compte</b> qu'une fois que le 
                <b>niveau</b> a été indiqué  et que la <b>convention
                de stage</b> a été téléversée (cela implique d'avoir enregistré
                les modifications apportées au stage).</p>
                <p>En cas de co-encadrement, vous pouvez modifier le taux d'encadrement
                pour permmettre un partage du volant d'heures</p>
                <p>Vous pouvez utiliser le champ commentaire afin d'indiquer toute information supplémentaire que vous jugez utile.</p>
                <p>Depuis l'année 2022-2023, cette prise en compte de charge est possible pour un étudiant
                d'Université Paris Cité, mais également pour un étudiant d'une
                autre université.</p>
            </div>
        </div>
    {% endblock stage_info %}

    {% if tab.canEdit %}
        <header id='editStagesError' class="w3-container w3-red " style="display:none">
            <span onclick="this.parentElement.style.display='none'" class="w3-button w3-display-topright">&times;</span>
            <p class='w3-center'>Red often indicates a dangerous or negative situation.</p>
        </header>
            
        <br>
        <form id='stagesForm' action='' >
            <p>Vous déclarez encadrer l'équivalent de <span data-bind='text: $root.affStages()'>&nbsp;</span> stage(s)</p>
            <p>Pour un volume dans le référentiel de <span data-bind='text: d.volume()'>&nbsp;</span> hETD</p>    
            <table class='stage' data-bind='visible: d.stages().length > 0'>
                <thead>
                </thead>
                <tbody data-bind='foreach: d.stages'>
                    <tr  class = ''>
                        <th></th>
                        <th>N° etudiant</th>
                        <th>Établissement</th>
                        <th>Niveau</th>
                        <th>taux d'encadrement</th>
                    </tr>
                    <tr class = 'stage' data-bind="style: { 'background-color': withOK() ? '#98fb98' : '#FADADD' }">
                        <td><a href='#' data-bind='click: $root.removeStage'><i class="fa fa-trash" style="color:red"></i></a></td>
                        <td data-bind='text: num'/></td>
                        {#<td data-bind='text: nom'/></td>}#
                        {# <input data-bind='textinput: nom'  oninput='stagesModel.d.stages.valueHasMutated()'/><td> #}
                        <td data-bind='text: univ'/></td>
                        <td class='w3-center'><select data-bind='options: $root.lList, value: level'  onchange='stagesModel.d.stages.valueHasMutated()'></select></td>
                        <td class='w3-center'><select data-bind='options: $root.tList, value: co'  onchange='stagesModel.changeTaux()'></select></td> 
                        {#<td class='w3-center'><input type='checkbox' data-bind='checked: co' onchange='stagesModel.changeCoEncadrement();' /></td>#}
                    </tr><tr class = 'stage' data-bind="style: { 'background-color': withOK() ? '#98fb98' : '#FADADD' }">
                        <td></td>
                        <th>Nom</th>
                        <td colspan='4'><input data-bind='textinput: nom' oninput='stagesModel.d.stages.valueHasMutated()' style='width: 97%'/></td>
                    </tr><tr class = 'stage' data-bind="style: { 'background-color': withOK() ? '#98fb98' : '#FADADD' }">
                        <td></td>
                        <th>Formation</th>
                        <td colspan='4'><input data-bind='textinput: formation' oninput='stagesModel.d.stages.valueHasMutated()' style='width: 97%'/></td>
                    </tr><tr class = 'stage' data-bind="style: { 'background-color': withOK() ? '#98fb98' : '#FADADD' }">
                        <td></td>
                        <th>Commentaire</th>
                        <td colspan='4'><input data-bind='textinput: cm' oninput='stagesModel.d.stages.valueHasMutated()'style='width: 97%' /></td> 
                    </tr><tr class = 'stage' data-bind="style: { 'background-color': withOK() ? '#98fb98' : '#FADADD' }">
                        <td></td>
                        <th>Convention</th>
                        <td>
                            <a data-bind="attr: { href: url }, visible: withDocument" target='_blank'>voir la convention</a>
                            <a data-bind="attr: { href: url }, hidden: withDocument" target='_blank'>Pas encore de convention chargée</a>
                        </td>
                        <td colspan='3'>
                            {#<div data-bind="fileDrag: fileData">#}
                                <input type="file" data-bind="fileInput: fileData">
                            {#</div>#}
                    </tr>
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan='4'>----</td>
                    </tr>
                </tfoot>
            </table>
            
            <p data-bind="visible: changed()"><button data-bind='click: save' class="w3-button w3-orange w3-round-xlarge" style="width:30em"> &gt;&gt;&gt;&gt;&gt; Enregistrer &lt;&lt;&lt;&lt;&lt; </button></p>
            <p>
                <input  data-bind='value: numetu' style='width: 10em;' placeholder='N° étudiant'/>
                <select data-bind="options: uList, value: univ"></select>
                <button data-bind='click: addStage'>Ajouter un stage</button></p>
            <br>
        </form>
    {% else %}
        <h3>Encadrement des Stages</h3>
        {% if tab.error =="" %}

        Volume pris en compte : {{tab.volume}} hETD<br>
        <table>
            <tr>
                <th>N° etudiant</th>
                <th>Nom</th>
                <th>Établissement</th>
                <th>Niveau</th>
                <th>Formation</th>
                <th>Commentaire</th>
            </tr>
            {% for S in tab.stageList %}
             <tr >
                <td>{{S.num}}</td>
                <td>{{S.nom}}</td>
                <td>{{S.univ}}</td>
                <td>{{S.level}}</td>
                <td>{{S.formation}}</td>
                <td>{{S.cm}}</td>
             </tr>                  
            {% endfor %}            
        </table>
        {% else %}
        <h3>{{ tab.error}}</h3>
        {% endif %}
    
    {% endif %}
    </div>
</div>

{% if tab.canEdit %}    

<script>

var StagesModel = function(stages, volume) {
    var self = this;
    self.d = [];

// console.log('les stages ',stages);

    for(i=0;i<stages.length;i++){

//        stages[i].withDocument = ko.observable( (stages[i].file !== undefined) );
        stages[i].withDocument = ko.observable( (stages[i].withDocument) );
        stages[i].withLevel = ko.observable( (stages[i].level !== 'Niveau') );
        // stages[i].file = ko.observable(stages[i].file !== undefined );
        stages[i].file = ko.observable(stages[i].file ); // file est supposé contenir le mimetype du fichier ou "" si il n'y a pas eu de fichier téléchargé


        stages[i].nom = ko.observable(stages[i].nom);
        stages[i].co = ko.observable(stages[i].co);
        stages[i].cm = ko.observable(stages[i].cm);
        stages[i].level = ko.observable(stages[i].level);
        stages[i].url = '/{{App.appName}}/personne/loadConvention/{{ App.currentYear }}/{{ personne.id }}/'+stages[i].num;
        //stages[i].document = ko.observable(true);
        stages[i].formation = ko.observable(stages[i].formation)

        stages[i].withOK = ko.pureComputed(function() {
// console.log('withOK', this.withDocument(), this.withLevel(), this.nom().trim(), this.formation().trim());  
            return this.withDocument() && this.withLevel() && this.nom().trim() !=="" && this.formation().trim() !=="";
        }, stages[i]).extend({ notify: 'always' });
        
        stages[i].withDocument.subscribe(function(value){
            // console.log('Il y a un truc pour withDocument ', value);
        });
        stages[i].withLevel.subscribe(function(value){
            // console.log('Il y a un truc pour withLevel ', value);
        });
        stages[i].file.subscribe(function(value){
            // console.log('Il y a un truc pour file ', value);
        });

        stages[i].fileData = ko.observable({
            dataURL: ko.observable(),
            index: i,
        });
        stages[i].fileData.subscribe(function(ff){
            self.d.stages()[ff.index].withDocument(false);
        });

        stages[i].fileData().dataURL.subscribe(function(ff){
        });

        stages[i].level.subscribe(function(value){
            this.withLevel(this.level() !== 'Niveau');
        }, stages[i])


        stages[i].formation.subscribe(function(value){
            // console.log('Il y a un truc formation');
        })//console.log('trouvé pour ', self.d.stages()[i].num);


        stages[i].nom.subscribe(function(value){
            // console.log('Il y a un truc nom');
        })

    }

    self.d.stages = ko.observableArray(stages);
    self.d.volume = ko.pureComputed(function() {
        var v = Math.round(6*self.nbStages());  
        return (v>12)?12:v;     // on limite le volume de prise en compte des stages à 12h.
    }, this).extend({ notify: 'always' });
    
    self.numetu = ko.observable(''); //22017924  // 71602248
    self.uList =  ko.observableArray(univList);
    self.lList =  ko.observableArray(levelList);
    self.tList = ko.observableArray(tauxList);
    self.univ = ko.observable();

    self.nbStages = ko.pureComputed(function() {
        var count = 0;
        self.d.stages().forEach(stage => {
            if (stage.withOK()){
                count += eval(stage.co());
            }
        })
        return count;
    }, this);

    self.affStages = ko.pureComputed(function() {
        n = self.nbStages();
        e = Math.trunc(n);
        d = n-e;
        if (Math.abs(d - 0)<0.0001) f = "0";
        if (Math.abs(d -1/2)<0.0001) f = "1/2";
        if (Math.abs(d -1/3)<0.0001) f = "1/3";
        if (Math.abs(d -2/3)<0.0001) f = "2/3";
        if (Math.abs(d -1/6)<0.0001) f = "1/6";
        if (Math.abs(d -5/6)<0.0001) f = "5/6";
        if (e<1) return f;
        if (f=="0") return ""+e;
        return ""+e+" + "+f;
    }, this);


    self.getJSON = function(){
        return  { 'stages': ko.mapping.toJS(self.d.stages), 'volume': self.d.volume() };
    }

    self.getJSONString = function(){
        return JSON.stringify(self.getJSON());
    }

    self.changed = function(){
        self.d.stages.valueHasMutated();
        // console.log(self.initialJSONString, '\n___\n',self.getJSONString());
        var changed = self.initialJSONString !== self.getJSONString();
        return changed;
    };


    self.doAddStage = function(json){

        if (json==""){
            data = [];
            data.displayname='Pas trouvé'
            etape = ['Pas touvé'];
        } else {
            data = JSON.parse(json);
            etapeList = Array.isArray(data.supannetuetape)?data.supannetuetape:[data.supannetuetape];
            etape = [];
            
            etapeList.forEach(function(et){
                etape.push(et.replace(/ *{[^)]*} */g, ""));
            });
        }

        stage = {
            num: self.numetu(),
            univ: self.univ(),
            nom: data.displayname,
            level: data.level,
            co:'1',
            cm: "",
            url: '/{{App.appName}}/personne/loadConvention/{{ App.currentYear }}/{{ personne.id }}/'+self.numetu(),
            formation: (data.nom.charAt(0) === '"' && data.nom.charAt(data.nom.length -1) === '"')?data.nom.substr(1,data.nom.length -2):data.nom,
        };
        
        stage.nom = ko.observable(data.displayname);
        stage.level = ko.observable(data.level);
        stage.co = ko.observable('1');
        stage.cm = ko.observable("");
        stage.formation = ko.observable(stage.formation);

        stage.level.subscribe(function(value){
            // console.log('Il y a un truc level 2');
        })
        stage.nom.subscribe(function(value){
            // console.log('Il y a un truc nom 2');
        })

        stage.formation.subscribe(function(value){
            // console.log('Il y a un truc formation 2');
        })
        stage.withDocument = ko.observable(false);
        stage.withDocument.subscribe(function(value){
            // console.log('Il y a un truc avec withDocument 2 ', value);
        });

        stage.level.subscribe(function(value){
            this.withLevel(this.level() !== 'Niveau');
        }, stage)

        stage.file = ko.observable();
        stage.file.subscribe(function(value){
            // console.log('Il y a un truc avec file 2 ', value);
        });
        stage.withLevel = ko.observable(data.level !== 'Niveau');
        stage.withLevel.subscribe(function(value){
            // console.log('Il y a un truc avec withLevel 2 ', value);
        });

        stage.fileData = ko.observable({
            dataURL: ko.observable()
        });
        stage.fileData().dataURL.subscribe(function(dataURL){
            stage.withDocument(false);
        });

        stage.withOK = ko.computed(function() {
            // console.log('withOK 2', this.withDocument(), this.withLevel(), this.nom().trim(), this.formation().trim());  
            return this.withDocument() && this.withLevel() && this.nom().trim() !=="" && this.formation().trim() !=="";
        }, stage).extend({ notify: 'always' });


       self.d.stages.push(stage);    
    }


    self.addStage = function() {
        if ( self.numetu().trim() == ''){
            return;
        }
        if (self.univ() !== univList[0]){
            json = '{"uid":"","displayname":"","supannetuetape":"","etape":"","nom":"","level":"Niveau"}';
            self.doAddStage(json);
            return;
        }

        var posting = $.post('/{{ App.appName }}/personne/ldap/numetu',{
            searchValue: self.numetu(),
        });
                
        posting.done(function( json ) {
            self.doAddStage(json);            
            self.numetu('');
        });

    };

    self.changeTaux = function(){
        self.changed();
    }

    self.removeStage = function(stage) {
        self.d.stages.remove(stage);
    };
 
    self.save = function(form) {
        
        stages = ko.mapping.toJS(self.d.stages);
        // console.log(stages);
        lL = {}; // sera un objet dont les clés sont les num (étudiant) pour lesquel un fichier a été uploadé
        for(i=0;i<stages.length; i++){
            if (stages[i].fileData.dataURL !== undefined){
                lL[stages[i].num] = true;
            }
        }        
        for(i = 0; i<self.d.stages().length; i++){
            if (lL[self.d.stages()[i].num] === true ){
                self.d.stages()[i].withDocument(true);
                self.d.stages()[i].file('Pas chargé');
                // si c'est le cas on redonne la possibilité de voir le fichier
            }
        }
        self.d.stages.valueHasMutated();

        json = self.getJSONString();
//console.log('JSONString', json);        

        var jqxhr = $.post( "/{{ App.appName }}/personne/saveStages/{{ personne.id }}", {d: json} , function(data) {
        }).done(function(data) {
            //  si tout s'est bien passé, data contient success ainsi que la liste des num (etudiant) pour lesquels un fichier a été uploadé
            lignes = data.split("\n");
//            lL = {}; // sera un objet dont les clés sont les num (étudiant) pour lesquel un fichier a été uploadé
            if ('success' == lignes[0]) {
                self.initialJSONString = self.getJSONString();
                self.d.stages.valueHasMutated();
            } else {
                $('#editStagesError > p').html(data);
                document.getElementById('editStagesError').style.display = 'block'
            }
        })
        .fail(function() {
        })
        .always(function() {
        });
    };
    self.initialJSONString = self.getJSONString();
};


// console.log('le commentaire ', {{tab.SL.commentaire|raw}});
var stagesModel = new StagesModel({{ tab.SL.commentaire==''?'""':tab.SL.commentaire|raw }}, '{{ tab.SL.volume }}' );
ko.applyBindings(stagesModel, document.getElementById('stagesForm'));
stagesModel.initialJSONString = stagesModel.getJSONString();
stagesModel.changed();

function hasChangedStages(){
    var change = stagesModel.changed();
    return change ;
}

</script>
{% endif %}

