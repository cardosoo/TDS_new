{% extends "layout.html.twig" %}

{% block section %}

<style>

td, th {
  vertical-align: middle;
  text-align: left;
}

.td_centre{
  text-align: center !important;
}

.bold{
  background: AliceBlue;
  font-weight: bold;
}

.cache{
  display : none;
}
</style>



<div class="w3-cell-row">

  <div class="w3-container w3-cell">
    <div class="w3-card" style="max-width:1600px;margin-top:80px">    

      <h3>Potentiel Enseignant</h3>

      {% for P in PList %}
      <details>
        <summary>{{ P.statut.nom }} - {{ P.statut.obligation }}</summary>
        <div class='w3-row'>
          <div class='w3-half w3-card'>
            <table>
              <thead>
                <tr>
                  <th>Nombre</th>
                  <th>heures</th>
                  <th>Report</th>
                  <th>Situation</th>
                  <th>Référentiel</th>
                </tr>
              </thead>
              <tbody>
                </tr>
                  <td class='td_centre'>{{ P.count }}</td>
                  <td class='td_centre'>{{ P.total }}</td>
                  <td class='td_centre'>{{ P.totalReport }}</td>
                  <td class='td_centre'>{{ P.totalSituation }}</td>
                  <td class='td_centre'>{{ P.totalReferentiel }}</td>
                </tr>
              </tbody>
            </table>
          </div>
          <div class='w3-half'>
            <details>
              <summary>Situations Particulières</summary>
              <table>
                <thead>
                  <tr>
                    <th>nom</th>
                    <th>reduction</th>
                  </tr>
                </thead>
                <tbody>
                  {% for key in P.situation|keys %}
                  </tr>
                    <td>{{ key }}</td>
                    <td class='td_centre'>{{ P.situation[key] }}</td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
            </details>
            <details >
              <summary>Réfentiel</summary>
              <table>
                <thead>
                  <tr>
                    <th>nom</th>
                    <th>reduction</th>
                  </tr>
                </thead>
                <tbody>
                  {% for key in P.referentiel|keys %}
                  </tr>
                    <td>{{ key }}</td>
                    <td class='td_centre'>{{ P.referentiel[key] }}</td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
            </details>
          </div>
        </div>
      </details>
      
      {% endfor %}


    </div>
  </div>




<script>
    $(document).ready(function () {
        $('#list').DataTable({
            // order: [[0, "asc"]],
            dom: 'Bfrtip',
            paging: false,
            buttons: [
                'copy',
                'excel',
                'csv',
                {
                    extend: 'pdf',
                    orientation: 'landscape'
                }
            ]
        });
    });
</script>


{% endblock section %}


