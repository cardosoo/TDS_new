{% extends "layout.html.twig" %}

{% block section %}

<style>

td, th {
  vertical-align: middle;
  text-align: left;
}

.td_centre{
  text-align: center !important;
}

.bold{
  background: AliceBlue;
  font-weight: bold;
}

.cache{
  display : none;
}
</style>



<div class="w3-cell-row">

  <div class="w3-container w3-cell">
    <div class="w3-card" style="max-width:1600px;margin-top:80px">    

      <h3>Coût en HETD par diplôme</h3>
      <p>Total des heures dans les maquettes : {{total|f2}}</p>
      {% set ordre = 100 %}
      <table id='list'>
        <thead>
            <tr>
                <th class='cache'>ordre</th>
                <th>Maquette</th>
                <th>Diplome</th>
                <th>Étape</th>
                <th>Effectif</th>
                <th>Coût en HETD</th>
                <th>Coût composante</th>
            </tr>
        </thead>
        <tbody>
        {% for p in params %}{# |slice(0,1) #}
          {% set ordre = ordre+1 %}
          <tr>
            <td class='cache'>{{ordre}}</td>
            <td class='bold'>{{ p.composante.nom}}</td>
            <td class='bold'></td>
            <td class='bold'></td>
            <td class='bold'></td>
            <td class='bold'></td>
            <td class='bold'>{{ p.coutComposante|f2 }}</td>
          </tr>
          {% for l in p.list %}
            {% set ordre = ordre+1 %}
            <tr> 
              <td class='cache'>{{ordre}}</td>
              <td>{{l.maquette}}</td>
              <td>{{l.diplome}}</td>
              <td>{{l.etape.nom }}</td>
              <td>{{l.etape.nbetu}}</td>
              <td class='td_centre'>{{l.cout|f2 }}</td>
              <td></td>
            </tr>
          {% endfor %}
        {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

</div> 
<br>
<br>

<script>
    $(document).ready(function () {
        $('#list').DataTable({
            // order: [[0, "asc"]],
            dom: 'Bfrtip',
            paging: false,
            buttons: [
                'copy',
                'excel',
                'csv',
                {
                    extend: 'pdf',
                    orientation: 'landscape'
                }
            ]
        });
    });
</script>


{% endblock section %}


