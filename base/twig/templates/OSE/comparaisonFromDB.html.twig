                <td class='w3-centered {{(V.voeu_detail_heures.bonus - O.référentiel)|abs >0.1?'w3-red':''}}'>{{ V.voeu_detail_heures.bonus|f2 }} | {{ O.réferentiel|f2 }}</td>
            </tr>
