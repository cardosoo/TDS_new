<script>

    function deleteDoc(id, title, url){
        if (confirm('Confirmer la suppression du document :\n'+title)){
            $.post(
                '/{{App.appName}}/documentsME/deleteDoc/'+(url.split('/').at(-1)),
                function(data){
                    if (data!='Done'){
                        alert(data);
                    } else {
                        $("#"+id).remove();
                    };
                }
            ); 
        }

    }

    function renameDoc(id, title, url){
        var newTitle = prompt('Renommer le document :', title)
        if (null != newTitle){
            $.post(
                '/{{App.appName}}/documentsME/renameDoc/'+(url.split('/').at(-1)),
                { 'title': newTitle },
                function(data){
                    if (data=='Pb'){
                        alert("Il y a eu un problème lors du masquage de ce commentaire.");
                    } else {
                        html = buildDocHTML(id, newTitle, data);
                        $("#"+id).html(html);
                    };
                }
            ); 
        }
    }

    function buildDocHTML(id, title, url){
        return `<li id='${id}'>Maintenant 
    <button  onclick="deleteDoc('${id}', '${title}', '${url}')" class='w3-padding-small w3-margin-left w3-margin-right w3-tiny w3-button w3-round-large w3-red'><i class='fa fa-trash'></i></button>
    <a href='${url}' target='_blank'>${title}</a>
    <button  onclick="renameDoc('${id}', '${title}', '${url}')" class='w3-padding-small  w3-margin-left w3-tiny w3-button w3-round-large w3-grey'><i class='fa fa-edit'></i></button>
            </li>`
    }


    function tds_doSuccess(id, data){
        doc = JSON.parse(data);
        if (doc.error){
        } else {
            ul = $('#doc');

            nID = Math.round(Math.random()*32000);
            html = buildDocHTML(nID, doc.title, doc.url);
            ul.prepend(html);
            li = $('#uploaderFile'+id);
            li.remove();
        }
    } 

</script>

