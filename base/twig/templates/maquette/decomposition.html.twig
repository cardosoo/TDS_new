{% for D in M.diplomeList %}
    {% for E in D.etapeList%}
        {% for S in E.semestreList %}
        <p id="{{ S.code }} - {{ S.nom }}" > </p>
        <p>  </p>
        <div class="w3-card w3-round w3-white w3-margin">
                <div class="w3-bar w3-center w3-theme-l4 ">Semestre : {{ S.code }} - {{ S.nom }}</div>
                {% for UE in S.ueList %}
                    <div class="w3-card w3-round w3-theme-l5 w3-margin">
                        <div class="w3-bar">UE : {{ UE.code }} - {{ UE.nom }}</div>
                        {% for ECUE in UE.ecueList %}
                            {% if ECUE.enseignement.id %}
                            <div class="w3-white">
                                <i class="w3-margin-left"></i>
                                <i class="fas fa-long-arrow-alt-right w3-margin-left"></i>
                                <a href="/{{App.appName}}/enseignement/{{ ECUE.enseignement.id}}">ECUE : {{ ECUE.code }} - {{ ECUE.nom }}</a>
                            </div>
                            {% else %}
                            <div class="w3-white">
                                <i class="w3-margin-left"></i>
                                <i class="w3-margin-left"></i>
                                <i class="w3-margin-left"></i>
                                ECUE : {{ ECUE.code }} - {{ ECUE.nom }}
                            </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                {% endfor %}
        </div>
        {% endfor %}
    {% endfor %}
{% endfor %}

<div class="w3-white" style="min-height: 50em;">
</div>