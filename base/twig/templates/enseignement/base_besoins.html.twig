<div class="w3-card w3-round w3-white ">
    <div class="w3-white">
        <i class="fa fa fa-arrow-circle-right fa-fw w3-margin-right"></i>Besoins  {{ E.enseignement_besoins.besoins|f2 }} hETD
    </div>
    
    <div class="w3-container">
        <div class='w3-responsive' style="font-size: xx-small">
            <table class='w3-table-all w3-hoverable'>
                <thead>
                    <tr class='w3-light-blue' >
                        <th></th>
                        <th class="w3-center">CM</th>
                        <th class="w3-center">CTD</th>
                        <th class="w3-center">TD</th>
                        <th class="w3-center">TP</th>
                        <th class="w3-center">Ex</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <th>Nb Groupes</th>
                        <td class="w3-center">{{ E.cm|f2 }}</td>
                        <td class="w3-center">{{ E.ctd|f2 }}</td>
                        <td class="w3-center">{{ E.td|f2 }}</td>
                        <td class="w3-center">{{ E.tp|f2 }}</td>
                        <td class="w3-center">{{ E.extra|f2 }}</td>
                    </tr>
{% block nbSeances %}
                    <tr>
                        <th>Nb Séances</th>
                        <td class="w3-center">{{ E.s_cm|f2 }}</td>
                        <td class="w3-center">{{ E.s_ctd|f2 }}</td>
                        <td class="w3-center">{{ E.s_td|f2 }}</td>
                        <td class="w3-center">{{ E.s_tp|f2 }}</td>
                        <td class="w3-center">{{ E.s_extra|f2 }}</td>
                    </tr>
{% endblock nbSeances %}
{% block dureeSeance %}
                    <tr>
                        <th>Durée Séance</th>
                        <td class="w3-center">{{ E.d_cm|f2 }}</td>
                        <td class="w3-center">{{ E.d_ctd|f2 }}</td>
                        <td class="w3-center">{{ E.d_td|f2 }}</td>
                        <td class="w3-center">{{ E.d_tp|f2 }}</td>
                        <td class="w3-center">{{ E.d_extra|f2 }}</td>
                    </tr>
{% endblock dureeSeance %}
{% block nbIntervenant %}
                    <tr>
                        <th>Nb Intervenant</th>
                        <td class="w3-center">{{ E.i_cm|f2 }}</td>
                        <td class="w3-center">{{ E.i_ctd|f2 }}</td>
                        <td class="w3-center">{{ E.i_td|f2 }}</td>
                        <td class="w3-center">{{ E.i_tp|f2 }}</td>
                        <td class="w3-center">{{ E.i_extra|f2 }}</td>
                    </tr>
{% endblock nbIntervenant %}
{% block nbSeancesParSemaine %}
                    <tr>
                        <th>Nb Séances/Sem</th>
                        <td class="w3-center">{{ E.n_cm|f2 }}</td>
                        <td class="w3-center">{{ E.n_ctd|f2 }}</td>
                        <td class="w3-center">{{ E.n_td|f2 }}</td>
                        <td class="w3-center">{{ E.n_tp|f2 }}</td>
                        <td class="w3-center">{{ E.n_extra|f2 }}</td>
                    </tr>
{% endblock nbSeancesParSemaine %}
{% block bonus %}
                    {% if E.bonus>0 %}
                    <tr>
                        <th>Bonus</th>
                        <td colspan='5' class="w3-center">{{ E.bonus|f2 }}</td>
                    </tr>
                    {% endif %}
{% endblock bonus %}
                </tbody>
                <tfoot>
{% block totaux %}
                    <tr class='w3-light-blue'>
                        <th>hEQTD /Groupe</th>
                        <td class="w3-center">{{ C.cm   |f2 }}</td>
                        <td class="w3-center">{{ C.ctd  |f2 }}</td>
                        <td class="w3-center">{{ C.td   |f2 }}</td>
                        <td class="w3-center">{{ C.tp   |f2 }}</td>
                        <td class="w3-center">{{ C.extra|f2 }}</td>
                    </tr>
{% endblock totaux %}
                </tfoot>
            </table>
        </div>
        <br>
    </div>
</div>
<br>
