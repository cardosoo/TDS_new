<style>
    input:invalid {
        border: -2px dashed red;
    }

    input:valid {
        border: 1px solid gainsboro;
    }

    input:required:invalid,
    input:focus:invalid {
        background-image: url(data:image/png;base64,);
        background-position: right top;
        background-repeat: no-repeat;
        -moz-box-shadow: none;
    }

    input:required:valid {
        background-image: url(data:image/png;base64,);
        background-position: right top;
        background-repeat: no-repeat;
    }


    #image_preview>img,
    img {
        height: 130px;
    }

    .tool-tip {echo 1 | sudo tee /sys/module/hid_apple/parameters/fnmode

        position: absolute;
        right: 0;
        top: 0px
    }

    .icon {
        padding: 0em;
        width: 20px;
    }
</style>

<script type="text/javascript" src="/{{App.appName}}/assets/js/ImageTools.js"></script>
<script>
    var userForm;
    var userFormData;
    var theBlob;
    
    function isFormDataUserEditChanged(data) {
        for (var key of userFormData.keys()) {
            test = data.get(key);
            if (test.constructor.name == 'File') {
                if (test.name != '') {
                    return true;
                }
            } else {
                if (test.valueOf() != userFormData.get(key).valueOf()) {
                    return true;
                }
            }
        }
        return false;
    }

    $(document).ready(function () {
        userForm = $('#userEditForm')[0];
        userFormData = new FormData(userForm);
        theBlob = null;
        
        $("#userEditForm").submit(function (e) {
            //stop submit the form, we will post it manually.
            event.preventDefault();
            // Get form
            var form = $('#userEditForm')[0];
            // Create an FormData object 
            var data = new FormData(form);
            // If you want to add an extra field for the FormData

            if (theBlob){        
                data.set('upload_file', theBlob);
            }
            // disabled the submit button
            $("#submitBtn").prop("disabled", true);

            $.ajax({
                type: "POST",
                enctype: 'multipart/form-data',
                url: "/{{ App.appName }}/personne/edit/{{ personne.id }}",
                data: data,
                processData: false,
                contentType: false,
                cache: false,
                timeout: 800000,
                success: function (data) {
                    if ('success' == data) {
                        window.location.reload(true);
                    } else {
                        $('#editUserError > p').html(data);
                        document.getElementById('editUserError').style.display = 'block'
                        $("#submitBtn").prop("disabled", false);
                    }
                },
                error: function (e) {
                    $('#editUserError > p').html("Erreur réseau sans doute...");
                    document.getElementById('editUserError').style.display = 'block'
                    $("#submitBtn").prop("disabled", false);
                }
            });
        });
    });

    function preview_image() {
        var upload_file = document.getElementById("upload_file")
        ImageTools.resize(upload_file.files[0], {
            width: 320, // maximum width
            height: 240 // maximum height
        }, function(blob, didItResize) {
            // didItResize will be true if it managed to resize it, otherwise false (and will return the original file as 'blob')
            document.getElementById('preview').src = window.URL.createObjectURL(blob);
            // you can also now upload this blob using an XHR.
            theBlob = blob;
        });
    }



/* ImageTools vient de là : https://gist.github.com/dcollien/312bce1270a5f511bf4a
   et je l'ai trouvé là : https://stackoverflow.com/questions/2434458/image-resizing-client-side-with-javascript-before-upload-to-the-server
   
<input type="file" id="select">
<img id="preview">
