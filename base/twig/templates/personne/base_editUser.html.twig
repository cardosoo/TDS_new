*/

    function closeModalUserEditForm() {
        if (!isFormDataUserEditChanged(new FormData($('#userEditForm')[0]))) {
            document.getElementById('editUser').style.display = 'none';
            return;
        }

        if (confirm("Confirmer l'abandon de l'édition")) {
            document.getElementById('editUser').style.display = 'none';
            window.location.reload(false);
        } else {
        }
    }

</script>

<div id="editUser" class="w3-modal">

    <div class="w3-modal-content w3-card-4 w3-animate-zoom" style="max-width:600px">
        <div class="w3-center"><br>
            <span onclick="closeModalUserEditForm()" class="w3-button w3-xlarge w3-hover-red w3-display-topright"
                title="Close Modal">&times;</span>
        </div>

        {# Pour afficher les éventuelles erreurs #}
        <header id='editUserError' class="w3-container w3-red " style="display:none">
            <span onclick="this.parentElement.style.display='none'" class="w3-button w3-display-topright">&times;</span>
            <p class='w3-center'>Red often indicates a dangerous or negative situation.</p>
        </header>

        {# Le formulaire proprement dit #}
        <form id="userEditForm" enctype="multipart/form-data" class="w3-container" method='POST'
            action="/{{ App.appName }}/personne/edit/{{ personne.id }}">
            <div class="w3-section">
                {# pour la photo #}
                <div id="image_preview" class="w3-center">
                    <img id='preview' src="{{ personne.getPhotoUrl() }}" alt="Photo de {{ personne.prenom }} {{ personne.nom }}" />
                </div>
                <div class="w3-center"><label for="upload_file" class='w3-teal w3-tag w3-round w3-margin-bottom'>Changer
                        la photo</label></div>
                <input type="file" id="upload_file" name="upload_file[]" onchange="preview_image();" accept="image/*"
                    style="display:none" />

                {# Pour les informations professionnelles #}
                <div class="w3-container w3-center w3-teal">
                    Informations Professionnelles
                </div>

                <div class='w3-row'>
                    <div class="w3-half w3-tooltip">
                        <input class="w3-input" type="text" name='prenom' placeholder="prénom" value='{{ personne.prenom }}'
                            maxlength='30' required>
                        <span class="w3-text w3-tag tool-tip">Prénom</span>
                    </div>

                    <div class="w3-half w3-tooltip">
                        <input class="w3-input" type="text" name='nom' placeholder="nom" value='{{ personne.nom }}'
                            maxlength='30' required>
                        <span class="w3-text w3-tag tool-tip">Nom</span>
                    </div>
                </div>
                <div class="w3-row w3-tooltip">
                    {#
                    <input class="w3-input" type="email" name='prof_mail' placeholder="email pro"
                        value='{{ E.prof_mail }}' maxlength='50' pattern="\A[a-z0-9!#$%&'*+/=?^_‘{|}~-]+(?:\.[a-z0-9!#$%&'*+/=?^_‘{|}~-]+)*@(?:[a-z0-9](?:[a-z0-9-]*[a-z0-9])?\.)+[a-z0-9](?:[a-z0-9-]*[a-z0-9])?\z" required>
                    #}
                    <input class="w3-input" type="email" name='email' placeholder="email pro"
                        value='{{ personne.email }}' maxlength='50'>

                        <span class="w3-text w3-tag  tool-tip">mèl professionnel</span>
                </div>
                
                <div class="w3-row w3-tooltip">
                    <select name="labo" class="w3-select">
                        <option value='0'>Laboratoire ?</option>
                        {% for l in laboList %}
                        <option value='{{ l.id }}' {{ l.id==personne.labo.id?"selected":"" }}>
                            {{ l.nom }}
                        </option>
                        {% endfor %}
                    </select>
                    <span class="w3-text w3-tag  tool-tip">Laboratoire</span>
                </div>
                <div class="w3-row w3-tooltip">
                    <textarea class='w3-input' name='adresse'
                        placeholder="Adresse professionnelle en Markdown">{{ personne.adresse }}</textarea>
                    <span class="w3-text w3-tag  tool-tip">Adresse professionnelle - en Markdown</span>
                </div>
                <div class='w3-row'>
                    <div class="w3-half w3-tooltip">
                        <input type="tel" name='tel1' class="w3-input" placeholder="téléphone pro"
                            value='{{ personne.tel1 }}' maxlength='20'>
                        <span class="w3-text w3-tag  tool-tip">Téléphone</span>
                    </div>
                    <div class="w3-half w3-tooltip">
                        <input type="tel" name='tel2' class="w3-input" placeholder="téléphone pro"
                            value='{{ personne.tel2 }}' maxlength='20'>
                        <span class="w3-text w3-tag  tool-tip">Téléphone</span>
                    </div>
                </div>
                {# Pour les informations personnelles #}
                <div class="w3-container w3-center w3-teal w3-tooltip">
                    Informations Personnelles
                    <span class="w3-text w3-tag  tool-tip">Uniqumenent à destination de l'administration de l'UFR et la
                        foire</span>
                </div>

                <div class="w3-row w3-tooltip">
                    <textarea class='w3-input' name='info'
                        placeholder="Information personnelle en Markdown">{{ personne.info }}</textarea>
                    <span class="w3-text w3-tag  tool-tip">Informations personnelle - en Markdown</span>
                </div>
                <button id='submitBtn' class="w3-button w3-block w3-green w3-section w3-padding"
                    type="submit">Modifier</button>
            </div>
        </form>
    </div>
</div>