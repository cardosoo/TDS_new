    <script>
        function preserveInitialValues(){
            var form = $( "form :input" ); 
            $.each( form, function( i, field ) {
                var f = $(field)
                if (field.hasAttribute('_id_' )){ // alors il s'agit d'un champ lié oneToMany
                    field.setAttribute('_value_', field.getAttribute('_id_'));
                    field.onchange = function(){
                        if ( this.getAttribute('_id_') != this.getAttribute('_value_') ){
                            $(this).parent("p").addClass('Modif');
                        } else {
                            $(this).parent("p").removeClass('Modif');
                        }
                    };
                } else if (field.getAttribute('type') == 'checkbox') {
                    field.setAttribute('_value_', field.checked?'true':'false' );
                    field.onchange = function(){
                        if ( this.value != this.getAttribute('_value_') ){
                            $(this).parent("p").addClass('Modif');
                        } else {
                            $(this).parent("p").removeClass('Modif');
                        }
                    };

                } else {  // c'est un champ normal
                    field.setAttribute('_value_', field.value);
                    field.onchange = function(){
                        if ( this.value != this.getAttribute('_value_') ){
                            $(this).parent("p").addClass('Modif');
                        } else {
                            $(this).parent("p").removeClass('Modif');
                        }
                    };
                }
            });
        }

        function hasChanged(changed){
            return ( ! $.isEmptyObject(changed['field'] )) || ( ! $.isEmptyObject(changed['MTM'] ));
        }

        function doBeforeUnload(event){
            changed = getChanged();
            if ( (changed === false ) || hasChanged(changed) ){
                event.preventDefault();
                event.returnValue = '';                    
            }  
        }

        function getChanged(){ // if not valid return false
            var form = $( "form :input" );
            var res = {'field': {}, 'MTM': {}, 'MTM_E': {}, 'MTM_I': {} }; 
            var valid = true;
            $.each( form, function( i, field ) {
                var value;
                if ( $(field).hasClass('NotGood') ) {
                    valid=false;
                }
                if (field.hasAttribute('_id_' )){ // alors il s'agit d'un champ lié oneToMany
                    value = field.getAttribute('_id_');
                } else if (field.getAttribute('type') == 'checkbox' ) { // alors il s'agit d'une checkbox
                    value = field.checked?'true':'false';
                } else {  // c'est un champ normal
                    value = field.value;
                }
                if (value != field.getAttribute('_value_')){
                    res['field'][field.name] = value;
                }
            });
            if (!valid) return false; // si ce n'est pas valide on retourne false

            var delList = $("tr[del]"); // on regarde maintenant si il y eu des suppression dans les associations manyToMany
            var hasDel = false;

            $.each(delList, function(i, tr){
                hasDel=true,
                name=tr.getAttribute('name');
                id = tr.getAttribute('_id_');
                res['MTM'][name+'_'+id] = 0;
                res['MTM_E'][name+'_'+id] = name;
                res['MTM_I'][name+'_'+id] = id;
            });

            return res;
        }

        $( document ).ready(function() {
            preserveInitialValues();
            window.addEventListener('beforeunload', doBeforeUnload);
        });

        function doSave(isCreation){
            changed = getChanged();
            if (changed == false ){
                window.alert('Certaines valeurs ne sont pas correctes !');
                return ;
            }
            if (! hasChanged(changed)){
                window.alert("Il n'y a rien à mettre à jour !");
                return ;
            }

            var params = $.param( changed);
            var type = isCreation?'PUT':'PATCH';
            $.ajax({
                url: '',
                type: type,
                data: params,
            })
            .done(function(data) {
                if (data=== "Done"){
                    window.removeEventListener('beforeunload', doBeforeUnload );
                    document.location.reload();
                } else if (data.startsWith("Done")){
                    window.removeEventListener('beforeunload', doBeforeUnload );
                    id = data.substring(4);
                    if (id=="-1"){
                        window.history.back();
                    } else {
                        url = new URL(document.location.href);
                        parts = url.pathname.split('/');
                        last = parts[parts.length-1];
                        if (Number.isFinite(Number.parseInt(last,10))){
                            parts.pop();
                        }
                        url.pathname = parts.join('/');
                        document.location.replace(url.href+"/"+id);
                    }
                } else {
                    window.alert('Il y a eu un problème lors de la mise à jour : '+"\n"+ data);
                }
            })
            .fail(function(data) {
                console.log('fail',data);
            })
            .always(function(data) {
                console.log('always',data);
            });
        }

        function doDelete(){
            console.log('doDelete');
            openModal();
            $.ajax({
                url: '',
                type: 'DELETE',
            })
            .done(function(data) {
                console.log('Done');
                modal = $('#modal_content');
                console.log(modal); 
                modal.html(data);
            })
            .fail(function(data) {
                console.log('Fail');
            })
            .always(function(data) {
                console.log('Always');
            });
        }


        function doDelete2(){
            closeModal();

            $.ajax({
                url: '',
                type: 'DELETE',
                data: 'confirm=on',
            })
            .done(function(data) {
                if (data == "Done"){
                    window.removeEventListener('beforeunload', doBeforeUnload );
                    document.location.href='/{{ App.appName }}/CRUD/';
                } else {
                    window.alert('Il y a eu un problème lors de la suppression : '+"\n"+ data);
                }
            })
            .fail(function(data) {
            })
            .always(function(data) {
            });
        }


        function closeModal(){
            $('#modal').removeClass('visible');
            $('#modal').addClass('hidden');
        }

        function openModal(){
            $('#modal').removeClass('hidden');
            $('#modal').addClass('visible');            
        }


        function doDeleteLink(elm, p){
            var tr = $(elm).parents('tr');
            if (tr.attr('del')){
                tr.removeAttr('del');
            } else {
                tr.attr('del','del');
            }
        }

