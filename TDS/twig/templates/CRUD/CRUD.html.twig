    <script>

    /* Cette fonction est utilisée par les fonction
       autocomplete pour les relations oneToMany
       Elle permet de mettre la classe CSS correspondant
       à l'état actif de la sélection.
    */
    function setActif(what, actif){
        if (actif==""){
            what.removeClass("passif");
        } else {
            what.addClass("passif");
        }
    }

    function setAutocomplete(elmId, url){
        $( elmId ).autocomplete({
            source: url,
            select: function(event, ui) {
                $( this ).attr("_id_", ui.item.id)
                $( this ).removeClass( "NotGood");
                setActif($(this), ui.item.id ==0 || ui.item.actif);
            },
            change: function( event, ui ) {
                setActif($(this), ui.item.id ==0 || ui.item.actif);
                if (ui.item) {
                    if ( $(this).attr("_id_") != ui.item.id )  {
                    $(this).addClass( "NotGood" );
                    }    
                } else {
                    $(this).addClass( "NotGood" );
                }  
            }
        })
        .autocomplete( "instance" )._renderItem = function( ul, item ) {
        return $( "<li>" )
            .append( "<div class='"+item.actif+"'>" + item.label+"</div>" )
            .appendTo( ul );
        };;
    }
    </script>

    {% block asidenav %}
    <nav id='menu'>
        {% if isCreation %}
        <p> <button type="button" onclick='doSave(true)'>Créer</button></p>
        {% else %}
        <p> <button type="button" onclick='doSave(false)'>Enregister</button></p>
        <p> <button type="button" onclick='doDelete()'>Supprimer</button></p>
        {% endif %}
