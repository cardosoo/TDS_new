        background: lightcoral !important;
    }

    input.passif{
        text-decoration: line-through blue !important;
        color: blue !important;
        background: lightcoral !important;
    }


    tr.passifLink td, 
    tr.passifLink th {
        text-decoration: line-through darkblue !important;
        color: darkblue !important;
        background: lightcoral !important;
    }

    div.passif  {
        text-decoration: line-through blue !important;
        color: blue !important;
    }

    span.searchMark {
        font-weight: bolder;
    }

</style>