{% if App.cmpl.withMarkdown %}
    <link rel="stylesheet" href="/{{ App.appName }}/assets/css/markdown.css"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-eOJMYsd53ii+scO/bJGFsiCZc+5NDVN2yr8+0RDqr0Ql0h+rP48ckxlpbzKgwra6" crossorigin="anonymous">
{% endif %}

{% if App.cmpl.withCKEditor %}
    <link rel="stylesheet" href="https://cdn.ckeditor.com/ckeditor5/44.1.0/ckeditor5.css" crossorigin>
{% endif %}


<link rel="stylesheet" href="/{{ App.appName }}/assets/w3-css/w3.css"> 
{% if not App.debug %}
    {% if App.currentYear == App.officialYear %}
        <link rel="stylesheet" href="/{{ App.appName }}/assets/w3-css/w3-theme-blue-grey.css">
    {% elseif App.currentYear > App.officialYear%}
        <link rel="stylesheet" href="/{{ App.appName }}/assets/w3-css/w3-theme-light-green.css"> 
    {% else %}
        <link rel="stylesheet" href="/{{ App.appName }}/assets/w3-css/w3-theme-deep-orange.css"> 
    {% endif %}
{% else %}
    {% if App.currentYear == App.officialYear %}
        <link rel="stylesheet" href="/{{ App.appName }}/assets/w3-css/w3-theme-red.css">
    {% elseif App.currentYear > App.officialYear%}
        <link rel="stylesheet" href="/{{ App.appName }}/assets/w3-css/w3-theme-lime.css"> 
    {% else %}
        <link rel="stylesheet" href="/{{ App.appName }}/assets/w3-css/w3-theme-amber.css"> 
    {% endif %}
{% endif %}
  <link rel="stylesheet" href='/{{ App.appName }}/assets/google/OpenSans.css'> 
  <link rel="stylesheet" href="/{{ App.appName }}/assets/font-awesome-5/css/all.css">
  <link rel="stylesheet" href="/{{ App.appName }}/assets/tipped/dist/css/tipped.css"/>


<style>
    tr.passif td, 
    tr.passif th,
    li.passif {
        text-decoration: line-through blue !important;
