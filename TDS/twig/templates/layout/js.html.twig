{% if App.auth.isAuth %}
<script>
  var alive = setInterval(stayAlive, 1000*60*1); // pour faire un truc toutes les 1 minutes


  function setConnection(active){
    var connect_link = document.getElementById('connect_button');
    var connect_button = document.getElementById('connect_button');
    var href = "/{{ App.appName }}/auth/log"+(active?"out":"in");
    var className = "w3-bar-item w3-button w3-right w3-"+(active?'light-green':'red');
    var content = (active?'Déc':'C')+"onnexion...";
//    connect_button.href=href;
//    connect_button.innerHTML=content;
    connect_button.href=href;
    connect_button.innerHTML=content;
    connect_button.className=className;
    connect_link.href=href;
    connect_link.innerHTML=content;

  //  console.log(connect_button);
  }


  function transferComplete(evt) {
  //  console.log('transfertComplete');
    setConnection(true);
  }

  function transferFailed(evt) {
  //  console.log('transfertFailed');
    setConnection(false);
  }

  function transferCanceled(evt) {
//    console.log('transfertCanceled');
    setConnection(false);
  }

  function loadEnd(e) {
//    console.log('loadEnd');
  }


  function stayAlive(){
    var oReq = new XMLHttpRequest();

//    oReq.addEventListener("progress", updateProgress, false);
    oReq.addEventListener("load", transferComplete, false);
    oReq.addEventListener("error", transferFailed, false);
    oReq.addEventListener("abort", transferCanceled, false);
    oReq.addEventListener("loadend", loadEnd, false);

    oReq.open("get", "/{{ App.appName }}/alive", true);
    oReq.send();
  }
  
  

</script>
{% endif %}

