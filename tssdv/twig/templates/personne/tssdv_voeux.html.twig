{% extends "personne/base_voeux.html.twig" %}


{% block anciennete_titre %}
                    <th class="w3-center" title="Validation dans le Tableau de Service">Valid</th> 
                    <th  class="w3-center" title="Domaines associés">Dom</th>
{% endblock anciennete_titre %}


{% block anciennete_voeu %}                    
                    <td class="w3-center" >
                    {% if v.etat_ts == 2%}
                    <i class="far fa-question-circle"></i>
                    {% elseif v.etat_ts == 3%}
                    <i class="far fa-check-circle"></i>
                    {% endif %}
                    </td>
                    <td>
                        {% for DL in v.enseignement.domaine_enseignementList %}
                            <div>{{ DL.domaine.acronyme }}</div>
                        {% endfor %}    
                    </td>
{% endblock anciennete_voeu %}

{% block correspondant_titre %}
                    <th class="w3-center" title="Responsable de l'enseignement">Resp</th> 
{% endblock correspondant_titre %}

{% block anciennete_bilan %}
                    <td {{ not compact?'colspan="9"':''}} style='text-align: right;'> écart à la charge&nbsp;:</td>
                    <td></td>
{% endblock anciennete_bilan %}


{% block action %}
    {% if (personne.id == App.auth.user.id) and (App.phaseList[App.phase].withAjouterVoeux) %}
        
        {% set needValidation = false %}
        {% for v in personne.voeuList %}
            {% if v.etat_ts <2  %}
                {% set needValidation = true %}
            {% endif %}
        {% endfor %}
        
        {# suppression de la demande de validation globale : 25/10/2024
        {% if needValidation %}
            <button onclick="window.location='/{{ App.appName }}/personne/validerTousLesVoeux';" style='width:100%;' class="w3-button w3-green w3-small w3-padding-small">
                Demander la validation de tous les temps de service non validés
            </button>
        {% endif %}
        #}
    {% endif %}
{% endblock action%}


{% block total_heures_titre %}
    {% if App.auth.isAdmin or personne.isResponsableDomaine() or personne.isRHE() or personne.id == App.auth.user.id  %}
        {{ parent() }}
    {% endif %}
{% endblock total_heures_titre %}

