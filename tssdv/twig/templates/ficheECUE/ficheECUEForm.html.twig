{% if not readonly %}
    var mutualisation = initToastUIEditor('mentionMutualisationSDV');
    var prerequis = initToastUIEditor('prerequis');
    var competences = initToastUIEditor('competences');
    var connaissances = initToastUIEditor('connaissances');
    var syllabus = initToastUIEditor('syllabus');


    $( document ).ready(function() {

        document.getElementById('body_start').scrollIntoView({ behavior: "instant", block: "start" });
        initialData = getDataFromForm();

    });
{% endif %}


    function getDataFromForm(){
        form = document.getElementById('ficheECUE');
        data = new FormData(form);
        /*       
        data.set('mentionMutualisationSDV', document.getElementById('mentionMutualisationSDV').innerHTML);
        data.set('prerequis', document.getElementById('prerequis').innerHTML);
        data.set('competences', document.getElementById('competences').innerHTML);
        data.set('connaissances', document.getElementById('connaissances').innerHTML);
        data.set('syllabus', document.getElementById('syllabus').innerHTML);
        */
        data.set('mentionMutualisationSDV', mutualisation.getHTML());
        data.set('prerequis', prerequis.getHTML());
        data.set('competences', competences.getHTML());
        data.set('connaissances', connaissances.getHTML());
        data.set('syllabus', syllabus.getHTML());
        return data;
    }



    function doSave(button){
        doItQuandMeme();
        event.preventDefault();
        data = getDataFromForm();

        $.ajax({
            type: "POST",
            enctype: 'multipart/form-data',
            url: "/{{App.appName}}/ficheECUE/fiche/{{uid}}/{{name}}",
            data: data,
            processData: false,
            contentType: false,
            cache: false,
            timeout: 800000,
            success: function (data) {
                if ('success' == data) {
                    window.location='/{{App.appName}}/ficheECUE/gestion';
                    //window.location.reload(true);
                } else {
                    $('#editUserError > p').html(data);
                    document.getElementById('editUserError').style.display = 'block'
                    $("#submitBtn").prop("disabled", false);
                }
            },
            error: function (e) {
                $('#editUserError > p').html("Erreur réseau sans doute...");
                document.getElementById('editUserError').style.display = 'block'
                $("#submitBtn").prop("disabled", false);
            }
        });
    }

</script>
