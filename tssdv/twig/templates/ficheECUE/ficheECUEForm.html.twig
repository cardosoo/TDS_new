<script>
    function initCKEditor(id){
        elm = document.getElementById(id);
        editorConfig['initialData']=elm.innerHTML;
        editorConfig['placeholder']=elm.getAttribute('placeholder');
        BalloonEditor.create(elm, editorConfig);        
    }
    var form;
    var initialData;

    const { Editor }  = toastui;
    const { colorSyntax } = Editor.plugin;



    function initToastUIEditor(id){

        elm = document.getElementById(id);
        var Editor = toastui.Editor;

        var editor = new Editor({
                el: elm,
                plugins: [colorSyntax],
                height: 'auto',
                language: 'fr',
                initialEditType: 'wysiwyg',
                usageStatistics: false,
                initialValue: elm.innerHTML,
                hideModeSwitch: true,
            });
        return editor;
    }

