var tab = [];
function sdv_comp(){
    var t = [];
    $('.sdv_comp').each(function(){
        t[this.name] = Number(this.value.replace(",","."));
    });
    cout = t['hCM']*t['nCM']*1.5 + t['hTD']*t['nTD']*1 + t['hTP']*t['nTP']*t['nEnseignantsTP']; 
    console.log(cout);
    $("[name='cout']").val(cout+ ' hEQTD');
}

$('.sdv_comp').on('change', sdv_comp);

