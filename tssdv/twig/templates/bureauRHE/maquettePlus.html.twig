                <td><a href='/{{App.appName}}/personne/{{M.responsable.id}}'>{{ M.responsable.getGeneric() }}</a></td>
                <td><a href='/{{App.appName}}/personne/{{M.co_responsable.id}}'>{{ M.co_responsable.getGeneric() }}</a></td>
