{% extends "layout.html.twig" %}

{% block aside %}{% endblock %}

{% block section %}
    <div class="w3-container w3-content" style="max-width:1600px;margin-top:80px">    
        <h3>Liste des Enseignants rattachés au domaine {{ D.getGeneric() }}</h3>

        <table id='list'>
            <thead>
                <th>Prénom</th>
                <th>Nom</th>
                <th>Charge dans le domaine</th>
                <th>TS dans le domaine</th>
                <th>Écart à la charge</th>
            </thead>
            <tbody>
                {% for DP in D.domaine_personneList %}
                {% set P = DP.personne %}
                {# set Q = P.getChargeInDomaine(D.id) #}
                {# set charge = P.getChargeRepartition(D.id) #}
                {% set CR = P.getChargeRepartition() %}

                {% set charge = CR.charge - CR.serviceReferentiel %} {# calcul de la charge hors referentiel #}
                                                                     {# il faudrait aussi soustraire les situations non ? mais on dirait que c'est déjà pris en compte ? #}
                {% set s = 0%}
                {% for DP in personne.domaine_personneList %}
                    {% set s = s + DP.quotite %}
                    {% if DP.domaine.id == D.id %}
                        {% set quotInDomaine = DP.quotite %}
                    {% endif %}
                {% endfor %}

                <pre>
                    {{ dump(s) }}
                </pre>
                {% set Q =  (charge * DP.quotite / s ) %}

                <tr>
                    <td><a href='/{{App.appName}}/personne/{{P.id}}'>{{ P.prenom }}</a></td>
                    <td><a href='/{{App.appName}}/personne/{{P.id}}'>{{ P.nom }}</a></td>
                    <td class='w3-center'>{{ Q|f2 }} / {{ (charge * DP.quotite / s )|f2 }}</td>
                    <td class='w3-center'>{{ charge.serviceParDomaine[D.id ]|f2}} / {{ CR.serviceParDomaine[D.id ]|f2}}</td>
                    <td class='w3-center'>{{ charge.bilan|f2 }} / {{ CR.bilan|f2 }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div> 

    <script>
        $(document).ready(function () {
            $('#list').DataTable({
                // order: [[0, "asc"]],
                dom: 'Bfrtip',
                paging: false,
                buttons: [
                    'copy',
                    'excel',
                    'csv',
                    {
                        extend: 'pdf',
                        orientation: 'landscape'
                    }
                ]
            });
        });
    </script>

{% endblock %}
