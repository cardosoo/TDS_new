{% extends "layout.html.twig" %}

{% block aside %}{% endblock %}

{% block section %}
    <div class="w3-container w3-content" style="max-width:1600px;margin-top:80px">    
        <h3>Liste des Enseignants rattachés au domaine {{ D.getGeneric() }}</h3>

        <table id='list'>
            <thead>
                <th>Prénom</th>
                <th>Nom</th>
                <th>Statut</th> {# new #}
                <th>TS total</th> {# new #}
                <th>Charge théorique dans le domaine</th>
                <th>Charge d'enseignement dans le domaine</th>
                <th>Présentiel</th> {# new #}
                <th>Présentiel dans le domaine</th> {# new #}
                <th>Référentiel total</th> {# new #}
                <th>Situation particulières</th> {# new #}
                <th>Écart à la charge global</th>
                <th>Écart à la charge dans le domaine</th>
                <th>Présentiel hors ce domaine</th> {# devrait être heures hors SDV #}
                <th>Actif</th>
            </thead>
            <tbody>
                {% for DP in D.domaine_personneList %}
                    {% set P = DP.personne %}
                    {% set CR = P.getChargeRepartition() %}
                    {% set charge = CR.charge - CR.serviceReferentiel %}
                    {% set chargeTotale = CR.obligation - CR.bilan %}

                    {% set s = 0%}
                    {% set quot = 0 %}
                    {% for DP in P.domaine_personneList %}
                        {% set s = s + DP.quotite %}
                        {% if DP.domaine.id == D.id %}
                            {% set quot = DP.quotite %}
                        {% endif %}
                    {% endfor %}

                    {% set Q = (charge * quot / s ) %}
                    {% set Q2 = (CR.obligation * quot / s ) %}

                    <tr {{ P.actif?"":"class='passif';" }}>
                        <td><a href='/{{App.appName}}/personne/{{P.id}}'>{{ P.prenom }}</a></td>
                        <td><a href='/{{App.appName}}/personne/{{P.id}}'>{{ P.nom }}</a></td>
                        <td>{{P.statut.nom}}</td>
                        <td  class='w3-center'>{{ chargeTotale|f2}}</td>
                        <td  class='w3-center'>{{ Q2|f2}}</td>{# charge théorique dans le domaine #}
                        <td class='w3-center'>{{ Q|f2 }}</td> {# charge d'enseignement dans le domaine #}
                        <td  class='w3-center'>{{ CR.serviceEnseignement|f2}}</td> {# cahrge totale (présentiel) #}
                        <td class='w3-center'>{{ CR.serviceParDomaine[D.id ]|f2}}</td> {# charge dans le domaine #}
                        <td class='w3-center'>{{ CR.serviceReferentiel|f2 }}</td> 
                        <td class='w3-center'>{{ CR.reduction|f2 }}</td> 
                        <td class='w3-center'>{{ (-CR.bilan)|f2 }}</td> {# écart à la charge "total" #} 
                        <td class='w3-center'>{{ (CR.serviceParDomaine[D.id ]-Q)|f2 }}</td>  {# écart à la charge dans le domaine #}
                        <td class='w3-center'>{{ CR.serviceHorsDomaine|f2 }}</td> {# hors UFR SDV ? #}
                        <td class='w3-center'>{{ P.actif?"":"inactif" }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div> 

    <script>
        $(document).ready(function () {
            $('#list').DataTable({
                order: [[1, "asc"]],
                dom: 'Bfrtip',
                paging: false,
                buttons: [
                    'copy',
                    'excel',
                    'csv',
                    {
                        extend: 'pdf',
                        orientation: 'landscape'
                    }
                ]
            });
        });
    </script>

{% endblock %}
